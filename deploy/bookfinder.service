[Unit]
Description=Bookfinder API (FastAPI)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/bookfinder
Environment=PYTHONPATH=/opt/bookfinder/src
Environment=HOST=127.0.0.1
Environment=PORT=8010
ExecStart=/opt/bookfinder/.venv/bin/uvicorn bookfinder.api:app --host 127.0.0.1 --port 8010
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
