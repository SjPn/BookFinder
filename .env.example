# LLM backend: ollama | lmstudio
LLM_BACKEND=lmstudio

# Ollama (если LLM_BACKEND=ollama)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# LM Studio (если LLM_BACKEND=lmstudio)
LMSTUDIO_HOST=http://127.0.0.1:1234
# Имена моделей — как в LM Studio после загрузки (Developer → Local Server)
LMSTUDIO_CHAT_MODEL=qwen2.5-7b-instruct
LMSTUDIO_EMBED_MODEL=nomic-embed-text

# Python
PYTHONPATH=src
